@startuml fittrack-use-case-diagram

left to right direction

actor "Guest" as G

rectangle FitTrack {

  usecase "Open Application" as UC1
  usecase "Register Account" as UC2
  usecase "Verify Email" as UC3
  usecase "Log In" as UC4
  usecase "Log Out" as UC5
  usecase "View Workout Page" as UC6
  usecase "Start Active Workout" as UC7
  usecase "Create Workout Plan" as UC8
  usecase "Start Workout Plan" as UC9
  usecase "Save Workout Session" as UC10
  usecase "View Workout History" as UC11
  usecase "View Progress Chart" as UC12
  usecase "Browse Exercise Library" as UC13
  usecase "Search Exercises" as UC14
  usecase "View Exercise Details" as UC15
  usecase "Delete Workout Plan" as UC16

  ' guest relationships
  G --> UC1
  G --> UC2
  G --> UC4
  UC2 .> UC3 : <<include>>
  UC4 .> UC6 : <<extend>>

  ' workout page relationships
  UC6 .> UC7 : <<extend>>
  UC6 .> UC8 : <<extend>>
  UC6 .> UC9 : <<extend>>
  UC6 .> UC16 : <<extend>>
  UC7 .> UC10 : <<include>>
  UC8 .> UC10 : <<include>>
  UC9 .> UC10 : <<include>>

  ' workout history relationships
  UC11 .> UC12 : <<include>>

  ' exercise library relationships
  UC13 .> UC14 : <<extend>>
  UC13 .> UC15 : <<extend>>

  UC5 .> UC4 : <<include>>
}

actor "User" as U

' user relationships
U --> UC5
U --> UC6
U --> UC11
U --> UC13

@enduml
